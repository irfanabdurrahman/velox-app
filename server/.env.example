# Copy to .env and fill in. Never commit the real .env.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/velox?schema=public"

# Generate strong secrets, e.g.  openssl rand -base64 48
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"

ACCESS_TTL="900"          # access-token lifetime in seconds (15 min)
REFRESH_TTL_DAYS="30"     # refresh-token lifetime in days
PORT="4000"
CORS_ORIGIN="http://localhost:5173"   # comma-separated for multiple origins
NODE_ENV="development"

# AI provider (DeepSeek is OpenAI-compatible). Leave key empty to disable AI features.
DEEPSEEK_API_KEY=""
AI_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-chat"

# Optional: SMTP_*, VAPID_*, GOOGLE_*, MS_*, OAUTH_REDIRECT_BASE, WEB_ORIGIN, UPLOAD_DIR
# (see root .env.example) — each feature stays disabled until its vars are set.
