# ── Root env for docker-compose. Copy to .env and fill in. NEVER commit real secrets. ──

# PostgreSQL
POSTGRES_USER=velox
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=velox

# Auth secrets — generate with:  openssl rand -base64 48
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
ACCESS_TTL=900
REFRESH_TTL_DAYS=30

# Public origin the browser uses. Set to your domain, e.g. https://velox.example.com
CORS_ORIGIN=http://localhost
# Set true once TLS/HTTPS is in front (secure cookies). Keep false for plain-HTTP first boot.
COOKIE_SECURE=true

# Port the web app is published on (host side)
WEB_PORT=80

# Demo sample data (projects, tasks, demo accounts). OPT-IN — keep false for production.
# When true, 11 demo accounts are created; set SEED_DEMO_PASSWORD to override the shared password.
SEED_ON_START=false
SEED_DEMO_PASSWORD=

# AI provider (DeepSeek is OpenAI-compatible). Leave empty to disable AI features.
DEEPSEEK_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ── Optional integrations (features stay off until configured) ──
# Email (digests, notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Velox <no-reply@velox.app>
# Web Push (browser notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@velox.app
# SSO (leave blank to hide the buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:4000
WEB_ORIGIN=http://localhost:5173
# Attachment storage (defaults to server/uploads)
UPLOAD_DIR=/data/uploads
